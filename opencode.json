{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "manifest": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Manifest",
      "options": {
        "baseURL": "https://router.lhun.net/v1"
      },
      "models": {
        "auto": {
          "name": "Manifest Auto"
        }
      }
    }
  },
  "mcp": {
    "mcpjungle": {
      "enabled": true,
      "type": "remote",
      "url": "https://tools.lhun.net/mcp"
    },
    "chrome-devtools": {
      "command": ["npx", "-y", "chrome-devtools-mcp@latest"],
      "enabled": true,
      "type": "local"
    }
  }
}
